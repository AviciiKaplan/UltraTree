﻿<Window x:Class="UltraTree.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="UltraTree" Height="720" Width="1100">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,0,8">
            <TextBlock Text="Drive:" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <ComboBox Width="120" ItemsSource="{Binding Drives}" SelectedItem="{Binding SelectedDrive}" />
            <Button Content="Scan (NTFS Ultra Fast)" Margin="12,0,0,0" Padding="10,6"
                    Command="{Binding ScanCommand}" />
            <Button Content="Cancel" Margin="8,0,0,0" Padding="10,6"
                    Command="{Binding CancelCommand}" />
            <TextBlock Margin="16,0,0,0" VerticalAlignment="Center" Text="{Binding StatusText}"/>
        </StackPanel>

        <ProgressBar Grid.Row="1" Height="18" Minimum="0" Maximum="100"
                     Value="{Binding ProgressPercent}" />

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <GroupBox Header="Top Folders" Margin="0,0,8,0">
                <DataGrid ItemsSource="{Binding TopFolders}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeHuman}" Width="120"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>

            <GroupBox Header="Top Files" Grid.Column="1" Margin="8,0,0,0">
                <DataGrid ItemsSource="{Binding TopFiles}" AutoGenerateColumns="False" IsReadOnly="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Size" Binding="{Binding SizeHuman}" Width="120"/>
                        <DataGridTextColumn Header="Path" Binding="{Binding Path}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </GroupBox>
        </Grid>
    </Grid>
</Window>
